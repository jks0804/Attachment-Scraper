# Mail attachment scraper — credentials template.
#
# Copy this file to ".env" (same folder as scraper.py) and fill in the
# values for the provider(s) you want to use. Lines starting with "#" are
# ignored. You only need to fill in the section for the provider you plan
# to scrape — leave the other one commented out.
#
#     cp .env.example .env
#     # then edit .env
#
# NOTE: .env contains secrets. Do not commit it to git.

# ---------------------------------------------------------------------------
# Yahoo
# ---------------------------------------------------------------------------
# 1. Sign in at https://login.yahoo.com/account/security
# 2. Click "Generate app password", give it a name (e.g. "scraper"), copy
#    the 16-character password Yahoo shows you.
# 3. Paste it below. Spaces in the password are fine — leave them in.

YAHOO_EMAIL=you@yahoo.com
YAHOO_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ---------------------------------------------------------------------------
# Gmail
# ---------------------------------------------------------------------------
# 1. Turn on 2-Step Verification: https://myaccount.google.com/security
# 2. Create an app password: https://myaccount.google.com/apppasswords
#    (the "App passwords" page is only visible after 2-Step is on)
# 3. Paste the 16-character password below. Remove spaces if Google
#    displayed it with them — Gmail expects no spaces.

GMAIL_EMAIL=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
